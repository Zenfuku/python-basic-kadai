      "source": [
        "# 台形の辺の長さを設定\n",
        "top = 10      # 上辺（cm）\n",
        "bottom = 20   # 下辺（cm）\n",
        "height = 5    # 高さ（cm）\n",
        "\n",
        "# 台形の面積を計算\n",
        "area = (top + bottom) * height / 2\n",
        "\n",
        "# 結果を出力（単位付き）\n",
        "print(f\"{area}cm²\")"
      ],
